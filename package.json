{
  "name": "obsidian-kb-cli",
  "version": "0.3.0",
  "description": "CLI for the Karpathy-style LLM-wiki workflow on Obsidian vaults — lint, bootstrap, index, log. Companion to the obsidian-kb skill.",
  "homepage": "https://github.com/ab2891/obsidian-kb-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/ab2891/obsidian-kb-cli.git"
  },
  "bin": {
    "obkb": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "obsidian",
    "knowledge-base",
    "llm",
    "karpathy",
    "wiki",
    "lint"
  ],
  "author": "ab2891",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "kleur": "^4.1.5",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
